# Giscus comments (GitHub Discussions)
# Get these from https://giscus.app after enabling Discussions on your repo
# and installing the giscus GitHub App: https://github.com/apps/giscus
#
# Copy this file to `.env` and fill in your values. Vars must be prefixed with
# PUBLIC_ to be exposed to the client at build time.

PUBLIC_GISCUS_REPO=username/repo
PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxx
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxx
