---
import { AUTHOR } from "~/consts";
const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[var(--color-border)] py-10 text-sm text-[var(--color-fg-muted)]"
>
  <div
    class="mx-auto max-w-3xl px-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3"
  >
    <span>© {year} {AUTHOR.name}</span>
    <div class="flex gap-4">
      <a
        href="/rss.xml"
        class="hover:text-[var(--color-fg)] transition-colors"
        aria-label="RSS feed"
      >
        RSS
      </a>
      <a
        href={AUTHOR.social.github}
        class="hover:text-[var(--color-fg)] transition-colors"
        rel="noopener noreferrer"
        target="_blank"
      >
        GitHub
      </a>
      <a
        href={`mailto:${AUTHOR.email}`}
        class="hover:text-[var(--color-fg)] transition-colors"
      >
        Email
      </a>
    </div>
  </div>
</footer>
