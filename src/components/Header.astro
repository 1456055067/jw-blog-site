---
import { SITE_TITLE } from "~/consts";
import ThemeToggle from "~/components/ThemeToggle.astro";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/tags", label: "Tags" },
  { href: "/resume", label: "Resume" },
  { href: "/about", label: "About" },
];
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_oklch,var(--color-bg)_85%,transparent)] border-b border-[var(--color-border)]"
>
  <div class="mx-auto max-w-3xl px-6 h-16 flex items-center justify-between">
    <a
      href="/"
      class="font-mono text-sm tracking-tight font-semibold hover:text-[var(--color-accent)] transition-colors"
    >
      {SITE_TITLE}
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "px-3 py-1.5 text-sm rounded-md transition-colors",
              isActive(link.href)
                ? "text-[var(--color-fg)] font-medium"
                : "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
