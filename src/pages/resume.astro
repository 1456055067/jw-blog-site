---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { AUTHOR } from "~/consts";

const skills = [
  "MECM",
  "MPLS VPN",
  "Segment Routing",
  "PowerShell",
  "Python",
  "Server 2022",
  "Anycast",
  "IPv4",
  "IPv6",
  "IOS-XR",
  "Git",
  "DWDM",
  "Automation",
  "Cisco",
  "PA Firewalls",
  "Juniper Networks",
  "System Center",
  "vSphere",
  "vCenter",
  "vSAN",
  "ISE",
  "BGP",
  "IS-IS",
  "OSPF",
  "SRv6",
  "Azure DevOps",
  "Azure VMs",
  "AVD",
  "Azure Functions",
  "Service Bus",
  "Queue Storage",
  "EC2",
  "VPC",
  "SNS",
  "SQS",
  "Lambda",
  "DynamoDB",
  "AWS CDK",
  "Rust",
];

const experience = [
  {
    role: "Distinguished Engineer",
    company: "US Air Force",
    location: "Multiple Locations",
    dates: "07/2024 – Current",
    bullets: [
      "Leads engineering efforts for BOD and AFINC realignment.",
      "Designed, engineered, and procured aviation flyaway kits with delivery and fielding in four weeks from receiving the requirement.",
      "Provides engineering and strategic guidance for the Secretary of the Air Force Chief Information Officer.",
    ],
  },
  {
    role: "Engineering Systems Architect 4",
    company: "HII",
    location: "Virginia Beach, VA",
    dates: "03/2023 – 07/2024",
    bullets: [
      "Oversees and defines the strategic long-term objectives for network architectures, driving innovation and ensuring alignment with organizational vision and priorities.",
      "Lead development of network automation tool to provision datacenter networks and ensure that load balancers and appropriate network security protocols were implemented to align RMF controls.",
      "Engineered an MPLS network to provide a black-core network to transport different communities of interest.",
      "Developed custom automation tooling to Zero-Touch deploy Cisco ISE VMs, networking devices, and essential enterprise services.",
    ],
  },
  {
    role: "Network Development Engineer II",
    company: "Amazon",
    location: "Denver, CO",
    dates: "08/2022 – 03/2023",
    bullets: [
      "Led the design and development of a database to track tooling used across our organization using AWS CDK to deploy EC2, SNS, SQS, IAM policies and DynamoDB.",
      "Worked with a team to deploy new regions for Amazon Dedicated Cloud and generate documentation for the build.",
    ],
  },
  {
    role: "Engineering Systems Architect 3",
    company: "HII",
    location: "Virginia Beach, VA",
    dates: "08/2021 – 08/2022",
    bullets: [
      "Led the development of three classified networks and one unclassified network to support communications between remote sites and three regional datacenters.",
      "Led the design and development of highly specialized automation tools for deploying VMware with vSAN on Cisco UCS Servers, reducing full-cluster deployment time to 45 minutes.",
    ],
  },
  {
    role: "System Engineer",
    company: "US Navy",
    location: "Guantanamo Bay, Cuba",
    dates: "02/2021 – 06/2021",
    bullets: [
      "Implemented a comprehensive re-architecture of the active directory and virtual environment, improving core services.",
    ],
  },
  {
    role: "Network Administrator",
    company: "GDIT",
    location: "Norfolk, VA",
    dates: "02/2019 – 02/2021",
    bullets: [
      "Provided leadership and support to a cross-functional team in the replacement of network firewalls, ensuring successful implementation through training and mentorship initiatives.",
      "Led the initiative to organize and optimize network cabling and infrastructure within the data center, implementing new labeling for connections to facilitate streamlined troubleshooting.",
    ],
  },
  {
    role: "Technical Program Manager",
    company: "US Air Force",
    location: "Multiple Locations",
    dates: "02/2016 – 07/2024",
    bullets: [
      "Lead the development of automation tooling for Air Force Information Networks (AFIN) to reduce deployment and compliance timelines across network devices and ensure timely reporting to senior leaders.",
      "Lead IPv6 deployment efforts to transition AFIN to an IPv6-only architecture.",
      "Leading redesign to utilize Azure Local for the CSCS weapon system to remove dependencies on VMware and reduce costs.",
    ],
  },
];

const education = [
  {
    degree: "Master of Science, Information Technologies and Project Management",
    school: "Colorado Technical University",
    dates: "12/2022 – 10/2023",
  },
  {
    degree: "Bachelor of Science, Cyber Security & Legal Studies (Double Major)",
    school: "University of Maryland Global Campus",
    dates: "05/2017 – 05/2021",
  },
];
---

<BaseLayout title="Resume">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <div class="flex items-baseline justify-between gap-4 flex-wrap">
      <h1 class="text-4xl font-semibold tracking-tight">Resume</h1>
      <a
        href={`mailto:${AUTHOR.email}`}
        class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors"
      >
        {AUTHOR.email}
      </a>
    </div>

    <p class="mt-4 text-[var(--color-fg-muted)]">
      Distinguished Engineer focused on network architecture, automation, and
      cloud infrastructure across DoD and commercial environments.
    </p>

    <h2 class="mt-12 text-xl font-semibold tracking-tight">Skills</h2>
    <ul class="mt-4 flex flex-wrap gap-2">
      {
        skills.map((skill) => (
          <li class="font-mono text-xs px-2 py-1 rounded-md border border-[var(--color-border)] text-[var(--color-fg-muted)]">
            {skill}
          </li>
        ))
      }
    </ul>

    <h2 class="mt-12 text-xl font-semibold tracking-tight">Experience</h2>
    <div class="mt-6 space-y-8">
      {
        experience.map((job) => (
          <article>
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <h3 class="text-lg font-medium">
                {job.role}
                <span class="text-[var(--color-fg-muted)] font-normal">
                  {" "}— {job.company}
                </span>
              </h3>
              <span class="font-mono text-xs text-[var(--color-fg-muted)]">
                {job.dates}
              </span>
            </div>
            <p class="text-sm text-[var(--color-fg-muted)] mt-1">
              {job.location}
            </p>
            <ul class="mt-3 list-disc pl-5 space-y-1.5 text-[var(--color-fg)]">
              {job.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <h2 class="mt-12 text-xl font-semibold tracking-tight">Education</h2>
    <div class="mt-6 space-y-4">
      {
        education.map((ed) => (
          <article>
            <div class="flex items-baseline justify-between gap-4 flex-wrap">
              <h3 class="text-base font-medium">{ed.degree}</h3>
              <span class="font-mono text-xs text-[var(--color-fg-muted)]">
                {ed.dates}
              </span>
            </div>
            <p class="text-sm text-[var(--color-fg-muted)] mt-1">{ed.school}</p>
          </article>
        ))
      }
    </div>

    <h2 class="mt-12 text-xl font-semibold tracking-tight">Links</h2>
    <ul class="mt-4 space-y-1.5">
      <li>
        <a
          href={AUTHOR.social.github}
          class="text-[var(--color-accent)] hover:underline"
        >
          GitHub
        </a>
      </li>
      <li>
        <a
          href={AUTHOR.social.linkedin}
          class="text-[var(--color-accent)] hover:underline"
        >
          LinkedIn
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
