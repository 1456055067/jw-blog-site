---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/FormattedDate.astro";
import Comments from "~/components/Comments.astro";
import readingTime from "reading-time";

export async function getStaticPaths() {
  const posts = (
    await getCollection("blog", ({ data }) => !data.draft)
  ).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  return posts.map((post, i) => {
    // Tag-overlap related posts. Rank by # shared tags desc, then recency desc.
    // Empty if no tag overlap exists; the post page falls back to chronological.
    const myTags = new Set(post.data.tags);
    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => ({
        post: p,
        overlap: p.data.tags.filter((t) => myTags.has(t)).length,
      }))
      .filter((x) => x.overlap > 0)
      .sort(
        (a, b) =>
          b.overlap - a.overlap ||
          b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime()
      )
      .slice(0, 3)
      .map((x) => x.post);

    return {
      params: { slug: post.id },
      props: {
        post,
        related,
        // Newer post (more recent) is at a lower index because we sorted desc.
        newer: i > 0 ? posts[i - 1] : null,
        older: i < posts.length - 1 ? posts[i + 1] : null,
      },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
  related: CollectionEntry<"blog">[];
  newer: CollectionEntry<"blog"> | null;
  older: CollectionEntry<"blog"> | null;
}

const { post, related, newer, older } = Astro.props as Props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags } = post.data;
const readMinutes = Math.max(1, Math.round(readingTime(post.body ?? "").minutes));

const showRelated = related.length > 0;
const showChronological = !showRelated && (newer || older);
---

<BaseLayout
  title={title}
  description={description}
  ogImage={`/og/${post.id}.png`}
>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-24">
    <header class="mb-10">
      <div
        class="flex flex-wrap items-center gap-3 text-xs font-mono text-[var(--color-fg-muted)] uppercase tracking-widest mb-5"
      >
        <FormattedDate date={pubDate} />
        <span class="opacity-50">·</span>
        <span>{readMinutes} min read</span>
        {
          tags.length > 0 && (
            <>
              <span class="opacity-50">·</span>
              <span class="flex gap-2 normal-case tracking-normal">
                {tags.map((t) => (
                  <a
                    href={`/tags/${encodeURIComponent(t)}/`}
                    class="hover:text-[var(--color-accent)] transition-colors"
                  >
                    #{t}
                  </a>
                ))}
              </span>
            </>
          )
        }
      </div>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight leading-[1.1]">
        {title}
      </h1>
      <p class="mt-5 text-lg text-[var(--color-fg-muted)] leading-relaxed">
        {description}
      </p>
      {
        updatedDate && (
          <p class="mt-3 text-xs font-mono text-[var(--color-fg-muted)]">
            Updated <FormattedDate date={updatedDate} />
          </p>
        )
      }
    </header>

    <div
      class="prose dark:prose-invert prose-lg max-w-none text-[var(--color-fg)]"
    >
      <Content />
    </div>

    {
      showRelated && (
        <section
          class="mt-16 pt-8 border-t border-[var(--color-border)]"
          aria-label="Related posts"
        >
          <h2 class="text-sm font-mono text-[var(--color-fg-muted)] uppercase tracking-widest mb-4">
            Related
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {related.map((r) => (
              <a
                href={`/blog/${r.id}/`}
                class="group flex flex-col gap-2 p-4 rounded-md border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors"
              >
                <span class="text-xs font-mono text-[var(--color-fg-muted)]">
                  <FormattedDate date={r.data.pubDate} />
                </span>
                <span class="font-medium text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors">
                  {r.data.title}
                </span>
                <span class="text-sm text-[var(--color-fg-muted)] line-clamp-2">
                  {r.data.description}
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      showChronological && (
        <nav
          class="mt-16 pt-8 border-t border-[var(--color-border)] grid grid-cols-1 sm:grid-cols-2 gap-4"
          aria-label="Post navigation"
        >
          {newer ? (
            <a
              href={`/blog/${newer.id}/`}
              class="group flex flex-col gap-1 p-4 rounded-md border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors"
            >
              <span class="text-xs font-mono text-[var(--color-fg-muted)] uppercase tracking-widest">
                ← Newer
              </span>
              <span class="font-medium text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors">
                {newer.data.title}
              </span>
            </a>
          ) : (
            <span />
          )}
          {older ? (
            <a
              href={`/blog/${older.id}/`}
              class="group flex flex-col gap-1 p-4 rounded-md border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors sm:text-right"
            >
              <span class="text-xs font-mono text-[var(--color-fg-muted)] uppercase tracking-widest">
                Older →
              </span>
              <span class="font-medium text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors">
                {older.data.title}
              </span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }

    <Comments />

    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <a
        href="/blog"
        class="text-sm font-mono text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        ← all posts
      </a>
    </footer>
  </article>
</BaseLayout>
